# Backend
PORT=3000
CORS_ORIGIN=http://localhost:3001
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Free managed DB options (choose one)
# 1) Supabase Postgres (free tier)
# DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?schema=public

# 2) Neon Postgres (free tier)
# DATABASE_URL=postgresql://[USER]:[PASSWORD]@[HOST]/[DB]?sslmode=require&schema=public

# 3) Local Docker Postgres fallback
DATABASE_URL=postgresql://postgres:mynews-postgres@localhost:5432/mynews?schema=public

# External APIs
NEWS_API_KEY=your-newsapi-key
