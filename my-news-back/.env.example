# 백엔드 기본 설정
PORT=3000
CORS_ORIGIN=http://localhost:3001

# Neon PostgreSQL (권장)
# 주의: Prisma 7 기준으로 DATABASE_URL은 prisma.config.ts에서 사용됩니다.
# 아래에는 Neon의 Direct 연결 URL을 넣는 것을 권장합니다.
DATABASE_URL=postgresql://[NEON_USER]:[NEON_PASSWORD]@[NEON_DIRECT_HOST]/[DB_NAME]?sslmode=require&channel_binding=require

# 외부 API
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# 선택값
NAVER_NEWS_API_URL=https://openapi.naver.com/v1/search/news.json
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
