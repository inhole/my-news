// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  password      String
  name          String?
  refreshToken  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  bookmarks     Bookmark[]
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  news        News[]
}

model News {
  id          String     @id @default(uuid())
  title       String
  description String?
  content     String?
  contentHtml String?
  url         String     @unique
  urlToImage  String?
  publishedAt DateTime
  source      String
  author      String?
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  bookmarks   Bookmark[]

  @@index([publishedAt])
  @@index([categoryId])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  newsId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  news      News     @relation(fields: [newsId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, newsId])
  @@index([userId])
}

model WeatherCache {
  id        String   @id @default(uuid())
  lat       Float
  lon       Float
  data      Json
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([lat, lon])
  @@index([expiresAt])
}
