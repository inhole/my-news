// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  news        News[]
}

model News {
  id          String     @id @default(uuid())
  title       String
  description String?
  content     String?
  contentHtml String?
  url         String     @unique
  urlToImage  String?
  publishedAt DateTime
  source      String
  author      String?
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([publishedAt])
  @@index([categoryId])
}

model WeatherCache {
  id        String   @id @default(uuid())
  lat       Float
  lon       Float
  data      Json
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([lat, lon])
  @@index([expiresAt])
}
